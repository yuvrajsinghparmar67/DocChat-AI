# Copy this file to `.env` and fill in your values.

# --- LLM / Embeddings provider -----------------------------------------
# Google Gemini API (free tier). Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
CHAT_MODEL=gemini-3.5-flash
EMBEDDING_MODEL=gemini-embedding-2

# --- Image analysis (Gemini Vision) -------------------------------------
# Describes embedded charts/diagrams/photos (and transcribes scanned pages)
# so they become searchable and citable alongside the document's text.
ENABLE_IMAGE_ANALYSIS=true
MIN_IMAGE_SIZE_PX=80
MAX_IMAGES_PER_DOCUMENT=15

# --- App behavior ------------------------------------------------------
MAX_UPLOAD_MB=25
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
MAX_DOCS_PER_SESSION=20

# --- Storage -------------------------------------------------------------
UPLOAD_DIR=storage/uploads
VECTOR_DB_DIR=storage/vector_db
METADATA_PATH=storage/metadata.json

# --- CORS ------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173
